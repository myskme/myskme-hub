{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://myskme.github.io/myskme-hub/schema/tiku.schema.json",
  "title": "MYSKME 题库 · 扩展题库格式（词灵对决 / 无名之原 通用契约）",
  "description": "MYSKME 题库工坊统一题库格式 v1。出卷端（试卷即题库）产出、网站端（词灵对决/无名之原）导入，双方共用此契约。兑换码=卷号。",
  "type": "object",
  "required": ["name", "code", "mods"],
  "additionalProperties": true,
  "properties": {
    "ver": { "type": "integer", "description": "格式版本，当前为 1。结构变更时递增。" },
    "name": { "type": "string", "minLength": 1, "description": "题库名，如 “S1E7 派对藏宝图”。" },
    "code": { "type": "string", "pattern": "^[A-Za-z0-9_]{2,16}$", "description": "兑换码=卷号，如 S1E7。学生手输，仅限字母数字下划线。" },
    "desc": { "type": "string", "description": "一句话简介。" },
    "date": { "type": "string", "description": "出库日期，YYYY-MM-DD（可选）。" },
    "cat": { "type": "string", "description": "分类，供公共书架按类浏览，如 “语法陷阱” / “词汇” / “听力” / “主题词汇”。" },
    "pack": { "type": "string", "description": "系列/辑名，如 “语法陷阱训练营”。" },
    "level": { "type": "string", "description": "难度档：常规 / 炼狱（可选）。" },
    "tier": {
      "type": "string",
      "enum": ["free", "code", "svip"],
      "description": "分层：free=公共书架(无码直浏)；code=本期限定(兑换码=卷号，约2周后下放free)；svip=至尊内殿(炼狱/押题/独家，靠段位或专属码解锁)。缺省按 free。"
    },
    "mods": {
      "type": "object",
      "minProperties": 1,
      "description": "模块表。键为 m1/m2/m3…；值为题目数组。每题按形状区分：数组=配对，对象=选择/填空。",
      "patternProperties": {
        "^[mM][0-9]+$": {
          "type": "array",
          "minItems": 1,
          "items": { "oneOf": [ { "$ref": "#/definitions/pair" }, { "$ref": "#/definitions/mcq" } ] }
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "pair": {
      "type": "array",
      "description": "配对题：[词, 义, 难度?]。难度 1=基础 2=冲刺，可省略。",
      "minItems": 2,
      "maxItems": 3,
      "items": [
        { "type": "string", "minLength": 1 },
        { "type": "string", "minLength": 1 },
        { "type": ["integer", "string"] }
      ],
      "additionalItems": false
    },
    "mcq": {
      "type": "object",
      "description": "选择/填空题：q 中空格写 ___；ops 为选项；ans 为正确项下标（0 起，且 < ops 长度）；why 为精简解析；lv 1=基础 2=冲刺。",
      "required": ["q", "ops", "ans", "why"],
      "additionalProperties": true,
      "properties": {
        "q": { "type": "string", "minLength": 1 },
        "ops": { "type": "array", "minItems": 2, "items": { "type": "string" } },
        "ans": { "type": "integer", "minimum": 0 },
        "why": { "type": "string", "minLength": 1 },
        "lv": { "type": "integer", "enum": [1, 2] },
        "type": { "type": "string", "description": "保留：题型。缺省=选择/填空。未来：listening / cloze / reading / writing。" },
        "media": { "type": "object", "description": "保留：听力音频指针，如 {\"src\":\"audio/S1E7-1.opus\",\"dur\":12}。" },
        "passage": { "type": "string", "description": "保留：阅读语段（段落级阅读题型用）。" },
        "rubric": { "type": "array", "description": "保留：作文自评量规条目。" }
      }
    }
  }
}
